<%= form_with(model: @category, local: true) do |f| %>
  <% if @category.errors.any? %>
    <div class="mb-4 text-red-600">
      <%= @category.errors.full_messages.to_sentence %>
    </div>
  <% end %>
  <div class="mb-4">
    <%= f.label :name, class: "block font-semibold mb-1" %>
    <%= f.text_field :name, class: "w-full border rounded px-3 py-2" %>
  </div>
  <div>
    <%= f.submit class: "bg-blue-500 text-white px-4 py-2 rounded" %>
  </div>
<% end %>
